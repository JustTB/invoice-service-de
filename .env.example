# Auth
INVOICE_SERVICE_SECRET=change-me-to-a-long-random-string

# Seller identity (§14 UStG required fields)
SELLER_NAME=Muster GmbH
SELLER_ADDRESS_STREET=Musterstraße 1
SELLER_ADDRESS_CITY=Berlin
SELLER_ADDRESS_ZIP=10115
SELLER_STEUERNUMMER=12/345/67890        # Steuernummer OR USt-IdNr (at least one required)
SELLER_VAT_ID=DE123456789               # Required for cross-border EU B2B (reverse charge)
# SELLER_LOGO_PATH=./logo.png

# Database
DATABASE_URL=postgresql://invoice:invoice@localhost:5432/invoice

# Storage
STORAGE_TYPE=local                      # "local" | "s3"
STORAGE_PATH=./invoices
# S3_BUCKET=my-invoice-bucket
# S3_ENDPOINT=https://s3.example.com    # Leave empty for AWS, set for Minio/Cloudflare R2
# S3_ACCESS_KEY=...
# S3_SECRET_KEY=...

# Email
EMAIL_PROVIDER=resend                   # "resend" | "postmark" | "smtp"
EMAIL_FROM=rechnungen@example.com
RESEND_API_KEY=re_...
# POSTMARK_API_KEY=...
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=...
# SMTP_PASS=...

# Server
PORT=3000
